# =============================================================================
# Deployment Configuration
# =============================================================================

# Private key for deployment (with 0x prefix)
# WARNING: Never commit the actual private key! Use this template only.
PRIVATE_KEY=0x...

# Treasury address for platform fees
TREASURY_ADDRESS=0x...

# =============================================================================
# RPC Endpoints
# =============================================================================

# Ethereum Mainnet
ETHEREUM_RPC=https://eth.llamarpc.com
# ETHEREUM_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Ethereum Sepolia Testnet
SEPOLIA_RPC=https://rpc.sepolia.org
# SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# BSC Mainnet
BSC_RPC=https://bsc-dataseed.binance.org
# BSC_RPC=https://bsc-mainnet.nodereal.io/v1/YOUR_KEY

# BSC Testnet
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545

# Base Mainnet
BASE_RPC=https://mainnet.base.org
# BASE_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Base Sepolia Testnet
BASE_SEPOLIA_RPC=https://sepolia.base.org

# =============================================================================
# Contract Addresses (Auto-populated after deployment)
# =============================================================================

# ETHEREUM_VAULT_ADDRESS=0x...
# SEPOLIA_VAULT_ADDRESS=0x...
# BSC_VAULT_ADDRESS=0x...
# BSC_TESTNET_VAULT_ADDRESS=0x...
# BASE_VAULT_ADDRESS=0x...
# BASE_SEPOLIA_VAULT_ADDRESS=0x...

# =============================================================================
# API Keys for Contract Verification
# =============================================================================

# Etherscan (Ethereum)
ETHERSCAN_API_KEY=your_etherscan_api_key

# BscScan (BSC)
BSCSCAN_API_KEY=your_bscscan_api_key

# BaseScan
BASESCAN_API_KEY=your_basescan_api_key
