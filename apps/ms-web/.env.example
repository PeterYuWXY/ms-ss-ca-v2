# ======================================
# Web3 / Blockchain Configuration
# ======================================

# WalletConnect Project ID (required for wallet connection)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# RPC URLs (optional - defaults to public RPCs)
NEXT_PUBLIC_ETHEREUM_RPC_URL=https://eth.llamarpc.com
NEXT_PUBLIC_BSC_RPC_URL=https://binance.llamarpc.com
NEXT_PUBLIC_BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# ======================================
# Contract Addresses (REQUIRED - fill after deployment)
# ======================================

# Ethereum Mainnet Campaign Vault Contract
NEXT_PUBLIC_CAMPAIGN_VAULT_ETH=0x...

# BSC Mainnet Campaign Vault Contract  
NEXT_PUBLIC_CAMPAIGN_VAULT_BSC=0x...

# BSC Testnet Campaign Vault Contract
NEXT_PUBLIC_CAMPAIGN_VAULT_BSCTEST=0x...
