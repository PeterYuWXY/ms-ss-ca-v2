# Environment variables for CA Bot

# Telegram Bot
TELEGRAM_BOT_TOKEN=""

# MS API
MS_API_URL="http://localhost:3001"
MS_API_KEY=""

# Notification server port (MS API calls this to push offer alerts)
NOTIFY_PORT="3002"

# Database (same as MS API)
DATABASE_URL="postgresql://postgres:password@localhost:5432/ms_ss_ca?schema=public"

# CA Identity
CA_BOT_ID=""
CA_OWNER_WALLET=""

# Storage (for screenshots)
STORAGE_PROVIDER="supabase"
SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""

# Logging
LOG_LEVEL="info"
